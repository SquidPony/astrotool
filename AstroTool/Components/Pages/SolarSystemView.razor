@page "/solar-system"
@using AstroTool.Core.Services
@inject AstronomyService Astronomy
@inject IJSRuntime JS
@implements IDisposable

<div class="page-header">
    <span class="page-title">☀️ Solar System</span>
    <div style="display:flex;gap:8px">
        <button class="btn-astro @(_logScale ? "active" : "")" @onclick="ToggleLogScale">Log</button>
        <button class="btn-astro" @onclick="ZoomIn">+</button>
        <button class="btn-astro" @onclick="ZoomOut">-</button>
    </div>
</div>

<TimeControls @ref="_timeControls" OnTimeChanged="OnTimeChanged" />

<div class="sky-canvas-container" style="aspect-ratio:1;max-height:calc(100vh - 180px)">
    <canvas id="solarCanvas" class="sky-canvas"></canvas>
</div>

<div style="padding:12px 16px;font-size:12px;color:#4a6a8a">
    <div>Scale: @_scale px/AU • @(Astronomy.CurrentTime.ToString("yyyy-MM-dd HH:mm UTC"))</div>
</div>

@code {
    private TimeControls? _timeControls;
    private System.Threading.Timer? _renderTimer;
    private double _scale = 50;
    private bool _logScale = false;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _renderTimer = new System.Threading.Timer(
                async _ => await RenderSolarSystem(), null,
                TimeSpan.FromMilliseconds(200),
                TimeSpan.FromSeconds(30));
        }
    }

    private async Task OnTimeChanged()
    {
        await RenderSolarSystem();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RenderSolarSystem()
    {
        try
        {
            var positions = Astronomy.GetCurrentPositions();
            var orbitPaths = Astronomy.GetOrbitPaths();

            var planetData = positions.Select(kvp => new {
                name = kvp.Key,
                x = kvp.Value.X,
                y = kvp.Value.Y
            });

            var pathData = orbitPaths.ToDictionary(
                kvp => kvp.Key,
                kvp => kvp.Value.Select(p => new { x = p.X, y = p.Y })
            );

            await JS.InvokeVoidAsync("AstroTool.renderSolarSystem",
                "solarCanvas", planetData, pathData,
                new { scale = _scale, showLabels = true, logScale = _logScale });
        }
        catch { /* ignore */ }
    }

    private void ZoomIn() { _scale = Math.Min(200, _scale * 1.3); _ = RenderSolarSystem(); }
    private void ZoomOut() { _scale = Math.Max(10, _scale / 1.3); _ = RenderSolarSystem(); }
    private void ToggleLogScale() { _logScale = !_logScale; _ = RenderSolarSystem(); }

    public void Dispose() => _renderTimer?.Dispose();
}
